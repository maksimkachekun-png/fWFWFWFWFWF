@dp.message(AuthState.waiting_for_code, F.text.regexp(r'^\+7\d{10}$'))
async def phone_handler(message: types.Message, state: FSMContext):
    phone = message.text.strip()
    uid = message.from_user.id

    auth = MaxAuth()
    pending[uid] = {"auth": auth, "phone": phone, "status": "waiting_sms"}
    await state.update_data(phone=phone)

    msg = await message.answer("⏳ Подключаюсь к серверу...")

    def do_auth():
        try:
            if not auth.connect():
                pending[uid]["status"] = "error:connection_failed"
                return
            auth.session_init()
            time.sleep(0.5)
            if not auth.start_auth(phone):
                pending[uid]["status"] = "error:sms_failed"
                return
            pending[uid]["status"] = "sms_sent"
        except Exception as e:
            pending[uid]["status"] = f"error:{e}"

    threading.Thread(target=do_auth, daemon=True).start()
    await asyncio.sleep(5)

    if uid not in pending:
        return

    status = pending[uid].get("status", "")

    if status == "sms_sent":
        await msg.edit_text("✅ SMS отправлена. Введите код из 6 цифр:")
    elif status and status.startswith("error:"):
        err_text = status[6:]
        await msg.edit_text(f"❌ {err_text}", reply_markup=menu_keyboard())
        auth.close()
        del pending[uid]
        await state.clear()
    else:
        await msg.edit_text("⏳ Ожидание SMS... Введите код из 6 цифр:")

@dp.message(AuthState.waiting_for_code, F.text.regexp(r'^\d{6}$'))
async def code_handler(message: types.Message, state: FSMContext):
    uid = message.from_user.id
    if uid not in pending:
        return await message.answer("⏳ Сессия устарела. /start")

    data = await state.get_data()
    phone = data.get("phone", "")
    code = message.text.strip()
    auth = pending[uid].get("auth")

    if not auth:
        return await message.answer("⏳ Сессия устарела. /start")

    msg = await message.answer("⏳ Проверяю код...")

    result = None
    def do_verify():
        nonlocal result
        try:
            result = auth.verify_code(code)
        except Exception as e:
            result = {"error": str(e)}

    threading.Thread(target=do_verify, daemon=True).start()
    await asyncio.sleep(3)

    if not result:
        await asyncio.sleep(5)

    if not result:
        await msg.edit_text("❌ Таймаут проверки кода.", reply_markup=menu_keyboard())
        auth.close()
        del pending[uid]
        await state.clear()
        return

    if "error" in result:
        err = str(result["error"]).lower()
        if "wrong" in err or "invalid" in err:
            await msg.edit_text("❌ Неверный код. Попробуйте ещё раз.")
            return
        await msg.edit_text(f"❌ Ошибка: {result['error']}", reply_markup=menu_keyboard())
        auth.close()
        del pending[uid]
        await state.clear()
        return

    if result.get("needs_password"):
        pending[uid]["track_id"] = auth.track_id
        await state.set_state(AuthState.waiting_for_password)
        await msg.edit_text("🔐 Введите пароль 2FA:")
        return

    if result.get("needs_registration"):
        pending[uid]["status"] = "registering"
        pending[uid]["auth_token"] = auth.auth_token
        
        def do_register():
            try:
                reg = MaxRegistration(device_id=auth.device_id)
                if not reg.connect():
                    pending[uid]["status"] = "error:registration_connection"
                    return
                reg.session_init()
                time.sleep(0.5)
                reg.auth_token = auth.auth_token
                reg_result = reg.register(code, "User")
                reg.close()
                
                if reg_result.get("success"):
                    pending[uid]["token"] = reg_result["token"]
                    pending[uid]["device_id"] = reg.device_id
                    pending[uid]["status"] = "done"
                else:
                    pending[uid]["status"] = f"error:{reg_result.get('error', 'registration_failed')}"
            except Exception as e:
                pending[uid]["status"] = f"error:{e}"

        threading.Thread(target=do_register, daemon=True).start()
        await msg.edit_text("⏳ Регистрирую аккаунт...")
        
        for _ in range(30):
            await asyncio.sleep(1)
            if uid not in pending:
                return
            status = pending[uid].get("status", "")
            if status == "done":
                break
            if status and status.startswith("error:"):
                await msg.edit_text(f"❌ {status[6:]}", reply_markup=menu_keyboard())
                auth.close()
                del pending[uid]
                await state.clear()
                return
        
        if pending[uid].get("status") != "done":
            await msg.edit_text("❌ Таймаут регистрации.", reply_markup=menu_keyboard())
            auth.close()
            del pending[uid]
            await state.clear()
            return

    if result.get("token"):
        pending[uid]["token"] = result["token"]
        pending[uid]["device_id"] = auth.device_id
        pending[uid]["status"] = "done"

    if pending[uid].get("status") == "done":
        token = pending[uid]["token"]
        device_id = pending[uid].get("device_id", "")
        
        # Сохраняем Android токен
        uid_str = str(uid)
        if uid_str not in accounts:
            accounts[uid_str] = {}
        accounts[uid_str][phone] = {
            "token": token,
            "web_token": None,
            "device_id": device_id,
            "user_id": 0,
            "password": ""
        }
        save_data()
        
        # Отправляем Android токен
        android_data = json.dumps(accounts[uid_str][phone], indent=2, ensure_ascii=False)
        android_filename = f"ANDROID_{phone.replace('+', '')}.txt"
        
        await msg.edit_text("✅ Android токен получен! Конвертирую в WEB...")
        await message.answer_document(
            BufferedInputFile(android_data.encode('utf-8'), filename=android_filename),
            caption=f"✅ ANDROID токен для {phone}\n⚠️ Сохраните, сессия остаётся активной"
        )
        
        # Конвертируем в WEB (без разлогина Android)
        new_msg = await message.answer("🔄 Конвертирую в WEB токен...")
        
        def do_convert():
            return convert_android_to_web(token, device_id, phone, None)
        
        result = await asyncio.to_thread(do_convert)
        
        if result["success"] and result["web_token"]:
            # Обновляем web_token
            accounts[uid_str][phone]["web_token"] = result["web_token"]
            save_data()
            
            # Отправляем WEB токен
            web_data = json.dumps(accounts[uid_str][phone], indent=2, ensure_ascii=False)
            web_filename = f"WEB_{phone.replace('+', '')}.txt"
            
            await new_msg.edit_text("✅ Конвертация успешна! Отправляю WEB токен...")
            await message.answer_document(
                BufferedInputFile(web_data.encode('utf-8'), filename=web_filename),
                caption=f"✅ WEB токен для {phone}\nAndroid сессия остаётся активной"
            )
            
            await message.answer(
                f"🎉 <b>Готово!</b>\n\n"
                f"📱 Телефон: {phone}\n"
                f"✅ Android токен получен (сессия активна)\n"
                f"✅ WEB токен получен\n\n"
                f"Оба токена сохранены в файлах выше",
                parse_mode="HTML",
                reply_markup=menu_keyboard()
            )
        else:
            error = result.get("error", "Неизвестная ошибка")
            await new_msg.edit_text(
                f"⚠️ Android токен получен (сессия активна), но конвертация не удалась: {error}\n"
                f"WEB токен можно получить позже.",
                reply_markup=menu_keyboard()
            )
        
        auth.close()
        del pending[uid]
        await state.clear()
        return

    await msg.edit_text("❌ Неизвестная ошибка.", reply_markup=menu_keyboard())
    auth.close()
    del pending[uid]
    await state.clear()

