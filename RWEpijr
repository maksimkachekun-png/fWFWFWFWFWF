def logout_android(token: str, device_id: str) -> bool:
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(10)
        sock.connect(("api.oneme.ru", 443))
        ctx = ssl.create_default_context()
        ctx.check_hostname = False
        ctx.verify_mode = ssl.CERT_NONE
        sock = ctx.wrap_socket(sock, server_hostname="api.oneme.ru")

        sock.sendall(Packet(Opcode.SESSION_INIT, pack({
            "clientSessionId": 2,
            "mt_instanceid": uuid.uuid4().hex,
            "userAgent": {
                "deviceType": "ANDROID", "appVersion": "26.16.4",
                "osVersion": "Android 10", "timezone": "Europe/Moscow",
                "screen": "408dpi 1080x2292", "pushDeviceType": "GCM",
                "arch": "arm64-v8a", "locale": "ru",
                "buildNumber": 6704, "deviceName": "Google Pixel 7",
                "deviceLocale": "ru"
            },
            "deviceId": device_id
        })).to_bytes())
        time.sleep(0.5)

        sock.sendall(Packet(Opcode.LOGIN, pack({
            "token": token, "deviceId": device_id,
            "userAgent": {
                "deviceType": "ANDROID", "appVersion": "26.16.4",
                "osVersion": "Android 10", "timezone": "Europe/Moscow",
                "screen": "408dpi 1080x2292", "pushDeviceType": "GCM",
                "arch": "arm64-v8a", "locale": "ru",
                "buildNumber": 6704, "deviceName": "Google Pixel 7",
                "deviceLocale": "ru"
            }
        })).to_bytes())
        time.sleep(1)

        sock.sendall(Packet(Opcode.LOGOUT, pack({})).to_bytes())
        time.sleep(0.5)
        sock.close()
        return True
    except Exception as e:
        logging.error(f"[LOGOUT] Error: {e}")
        return False

# ==================== КОНВЕРТАЦИЯ ANDROID → WEB ====================

def convert_android_to_web(android_token: str, device_id: str = None, 
                           phone: str = None, password: str = None) -> dict:
    """
    Конвертирует Android токен в WEB токен
    Возвращает словарь с результатом в том же формате, что и в accounts.json
    """
    result = {
        "success": False,
        "web_token": None,
        "device_id": device_id or "unknown",
        "qr_data": None,
        "error": None,
        "token": android_token  # сохраняем оригинальный токен
    }

    qr_link = WebQRDeviceLink(phone=phone, password=password)
    if device_id:
        qr_link.device_id = device_id

    qr_result = {"qr": None, "token": None}

    def run_qr():
        qr_result["qr"], qr_result["token"] = qr_link.generate_and_wait(timeout=120, password=password)

    qr_thread = threading.Thread(target=run_qr)
    qr_thread.start()

    if not qr_link.qr_received.wait(30):
        qr_link.close()
        result["error"] = "QR generation timeout"
        return result

    result["qr_data"] = qr_link.qr_data or qr_link.qr_link
    result["device_id"] = qr_link.device_id

    logging.info(f"[CONVERT] Approving QR via Android API...")
    time.sleep(3)

    android = MaxAuth(device_id=device_id)
    if not android.connect():
        qr_link.close()
        result["error"] = "Android connection failed"
        return result

    try:
        android.session_init()
        time.sleep(0.5)
        
        login_res = android.login_by_token(android_token)
        if not login_res.get("success"):
            logging.warning(f"[CONVERT] Login warning: {login_res.get('error')}")
        
        time.sleep(1)
        
        approve_res = android.confirm_qr_scan(qr_link.track_id, qr_link.qr_link)
        logging.info(f"[CONVERT] Approve result: {approve_res}")
        time.sleep(2)

    except Exception as e:
        logging.error(f"[CONVERT] Android error: {e}")
    finally:
        android.close()

    qr_thread.join(timeout=120)

    if qr_link.login_complete.is_set() and qr_link.token:
        result["success"] = True
        result["web_token"] = qr_link.token
        logging.info("[CONVERT] Logging out from Android...")
        logout_android(android_token, device_id or qr_link.device_id)
    elif qr_link.password_required.is_set():
        result["error"] = "2FA_PASSWORD_REQUIRED"
    else:
        result["error"] = "WEB token timeout"

    qr_link.close()
    return result

