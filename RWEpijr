@dp.message(F.text.regexp(r'^\{.*\}$'))
async def convert_json_handler(message: types.Message):
    """Обработчик JSON формата"""
    try:
        data = json.loads(message.text.strip())
        token = data.get("token")
        device_id = data.get("device_id")
        password = data.get("password") or None
        
        if not token:
            await message.answer("❌ В JSON отсутствует поле 'token'")
            return
        
        if not device_id:
            # Если нет device_id в JSON, генерируем новый
            device_id = str(uuid.uuid4())
            await message.answer(f"⚠️ Device ID не указан, создан новый: <code>{device_id}</code>", parse_mode="HTML")
        
        await process_conversion(message, token, device_id, password)
        
    except json.JSONDecodeError:
        await message.answer("❌ Неверный JSON формат")
    except Exception as e:
        await message.answer(f"❌ Ошибка: {e}")

@dp.message(F.text.regexp(r'^[^|]+\|[^|]+(\|.*)?$'))
async def convert_pipe_handler(message: types.Message):
    """Обработчик формата через |"""
    parts = message.text.strip().split("|")
    
    if len(parts) < 2:
        await message.answer("❌ Неверный формат.\nНужно: <code>ТОКЕН|DEVICE_ID|ПАРОЛЬ</code>")
        return
    
    token = parts[0].strip()
    device_id = parts[1].strip()
    password = parts[2].strip() if len(parts) > 2 and parts[2].strip() else None
    
    if not token or not device_id:
        await message.answer("❌ Токен и Device ID обязательны")
        return
    
    await process_conversion(message, token, device_id, password)

async def process_conversion(message: types.Message, token: str, device_id: str, password: str = None):
    """Общая функция для конвертации"""
    msg = await message.answer(f"🔄 Конвертирую Android токен в WEB...")
    
    def do_convert():
        return convert_android_to_web(token, device_id, None, password)
    
    result = await asyncio.to_thread(do_convert)
    
    if result["success"] and result["web_token"]:
        # Формат как в accounts.json оригинального бота
        web_account = {
            "token": token,  # оригинальный android токен
            "device_id": device_id,
            "web_token": result["web_token"],
            "user_id": 0,
            "password": password or ""
        }
        
        await msg.edit_text(
            f"✅ <b>Конвертация успешна!</b>\n\n"
            f"📦 <b>WEB аккаунт:</b>\n"
            f"<pre>{json.dumps(web_account, indent=2, ensure_ascii=False)}</pre>\n\n"
            f"Android токен разлогинен.",
            parse_mode="HTML",
            reply_markup=get_main_keyboard()
        )
    elif result.get("error") == "2FA_PASSWORD_REQUIRED":
        await msg.edit_text(
            "❌ Требуется пароль 2FA!\n"
            "Отправьте JSON с паролем или через | :\n"
            "<code>ТОКЕН|DEVICE_ID|ПАРОЛЬ</code>",
            parse_mode="HTML",
            reply_markup=get_main_keyboard()
        )
    else:
        error = result.get("error", "Неизвестная ошибка")
        await msg.edit_text(
            f"❌ Ошибка конвертации: {error}",
            reply_markup=get_main_keyboard()
        )

